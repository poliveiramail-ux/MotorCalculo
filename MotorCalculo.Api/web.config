<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <!--
        hostingModel="inprocess" → processo corre dentro do worker process do IIS.
        Mais performance: sem overhead de comunicação inter-processo.
        Requer ASP.NET Core Module v2 (instalado com o .NET Hosting Bundle).
      -->
      <aspNetCore processPath="dotnet"
                  arguments=".\MotorCalculo.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
